#!/usr/bin/env bash
# ply — ledger de tarefas token-frugal, observável, paralelo por pull.
# Determinístico: o agente chama, recebe o mínimo. O script nunca chama LLM.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TASKS="$ROOT/tasks"; SPECS="$ROOT/specs"; JOURNAL="$ROOT/journal"
PLYD="$ROOT/.ply"; CLAIMS="$PLYD/claims"; USAGE="$PLYD/usage.tsv"
LESSONS="$TASKS/LESSONS.md"
TEST_CMD=""
[ -f "$PLYD/config" ] && . "$PLYD/config"
AS="${PLY_AS:-}"

die() { echo "erro: $*" >&2; exit 1; }
now() { date -u '+%FT%T'; }   # UTC: comparável com transcripts do Claude Code

# lê UM campo do frontmatter (bloco entre os dois '---', nunca o corpo)
fm() { # fm <arquivo> <chave>
  awk -v k="$2" '
    /^---[ \t]*$/ { d++; next }
    d==1 && $0 ~ "^"k":" { sub("^"k":[ \t]*",""); print; exit }
    d>=2 { exit }
  ' "$1"
}

resolve_kit() { # resolve_kit [--kit dir] → imprime path absoluto; exit 1 se não achar
  local kit=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --kit) kit="${2:-}"; [ -n "$kit" ] || die "--kit exige um diretório"; shift 2 ;;
      *) die "uso: ply init [--kit <dir>]" ;;
    esac
  done
  if [ -z "$kit" ] && [ -d "$ROOT/kit" ]; then kit="$ROOT/kit"; fi
  [ -n "$kit" ] || die "kit não encontrado — passe --kit <dir> ou use ./install.sh"
  kit="$(cd "$kit" && pwd)" || die "kit inválido: $kit"
  [ -f "$kit/CLAUDE.md" ] && [ -f "$kit/skills/ply-flow/SKILL.md" ] \
    || die "kit incompleto em $kit (faltam CLAUDE.md ou skills/ply-flow)"
  printf '%s\n' "$kit"
}

upsert_claude_block() { # upsert_claude_block <kit/CLAUDE.md> <dest/CLAUDE.md>
  local src="$1" dest="$2"
  if [ ! -f "$dest" ] || ! grep -q '<!-- ply:start -->' "$dest" 2>/dev/null; then
    { [ -f "$dest" ] && cat "$dest"
      [ -f "$dest" ] && [ -s "$dest" ] && printf '\n'
      printf '<!-- ply:start -->\n'
      cat "$src"
      printf '\n<!-- ply:end -->\n'
    } > "$dest.tmp" && mv "$dest.tmp" "$dest"
    return
  fi
  if ! grep -q '<!-- ply:end -->' "$dest" 2>/dev/null; then
    awk -v src="$src" '
      /<!-- ply:start -->/ {
        print
        while ((getline line < src) > 0) print line
        close(src)
        print "<!-- ply:end -->"
        after_start=1
        next
      }
      after_start { print; next }
      { print }
    ' "$dest" > "$dest.tmp" && mv "$dest.tmp" "$dest"
    return
  fi
  awk -v src="$src" '
    /<!-- ply:start -->/ {
      print
      while ((getline line < src) > 0) print line
      close(src)
      skip=1
      next
    }
    /<!-- ply:end -->/ { skip=0; print; next }
    !skip { print }
  ' "$dest" > "$dest.tmp" && mv "$dest.tmp" "$dest"
}

install_kit() { # install_kit <kit_dir>
  local kit="$1"
  mkdir -p "$ROOT/.claude/skills"
  rm -rf "$ROOT/.claude/skills/ply-flow"
  cp -R "$kit/skills/ply-flow" "$ROOT/.claude/skills/ply-flow"
  upsert_claude_block "$kit/CLAUDE.md" "$ROOT/CLAUDE.md"
}

cmd_init() {
  local kit
  kit=$(resolve_kit "$@") || exit 1
  mkdir -p "$TASKS" "$SPECS" "$JOURNAL" "$CLAIMS"
  [ -f "$PLYD/config" ] || printf '# comando de teste do projeto (test: da task vira argumento)\nTEST_CMD="pytest -q"\n' > "$PLYD/config"
  [ -f "$TASKS/_template.md" ] || cat > "$TASKS/_template.md" <<'EOF'
---
id: 000
title: TÍTULO
status: todo
spec:
depends:
files:
test:
size: S
---
AC:
- critério testável
EOF
  [ -f "$SPECS/_template.md" ] || cat > "$SPECS/_template.md" <<'EOF'
---
id: 000
title: TÍTULO
---
## Problema
(1–3 frases)

## Decisões
-

## Fora de escopo
-

## Riscos
-

<!-- Máx ~1 página. Passou disso? Divida a feature em duas specs. -->
EOF
  install_kit "$kit"
  echo "ply inicializado (kit: skill ply-flow + bloco CLAUDE.md). Edite .ply/config (TEST_CMD); crie: ./ply spec \"...\" e ./ply new \"...\""
}

next_id() { # next_id <dir>
  local max=0 f n
  for f in "$1"/[0-9]*.md; do
    [ -e "$f" ] || continue
    n=$(fm "$f" id)
    case "$n" in ''|*[!0-9]*) die "id inválido em $f — rode ./ply fsck" ;; esac
    n=$((10#$n)); [ "$n" -gt "$max" ] && max=$n
  done
  printf '%03d' $((max+1))
}

slugify() { echo "$1" | tr '[:upper:]' '[:lower:]' | LC_ALL=C tr -cs 'a-z0-9' '-' | sed 's/^-//;s/-$//' | cut -c1-40; }

render_new() { # render_new <template> <out> <id> <título>
  awk -v id="$3" -v ti="$4" '
    /^id:/    { print "id: " id; next }
    /^title:/ { print "title: " ti; next }
    { print }
  ' "$1" > "$2"
}

cmd_new() {
  local title="" spec="" dep="" id slug out
  while [ $# -gt 0 ]; do
    case "$1" in
      --spec) spec="${2:-}"; [ -n "$spec" ] || die "--spec exige um id"; shift 2 ;;
      --dep)  dep="${2:-}";  [ -n "$dep" ]  || die "--dep exige ids"; shift 2 ;;
      *) title="${title:+$title }$1"; shift ;;
    esac
  done
  [ -n "$title" ] || die "uso: ply new \"<título>\" [--spec N] [--dep \"ids\"]"
  id=$(next_id "$TASKS"); slug=$(slugify "$title"); out="$TASKS/${id}-${slug}.md"
  render_new "$TASKS/_template.md" "$out" "$id" "$title"
  if [ -n "$spec$dep" ]; then
    awk -v sp="$spec" -v dp="$dep" '
      /^spec:/    && sp != "" { print "spec: " sp; next }
      /^depends:/ && dp != "" { print "depends: " dp; next }
      { print }
    ' "$out" > "$out.tmp" && mv "$out.tmp" "$out"
  fi
  echo "criado: $out"
}

cmd_spec() {
  [ -n "${1:-}" ] || die "uso: ply spec \"<título>\""
  local id slug out; id=$(next_id "$SPECS"); slug=$(slugify "$1"); out="$SPECS/${id}-${slug}.md"
  render_new "$SPECS/_template.md" "$out" "$id" "$1"
  echo "criado: $out — preencha Problema/Decisões/Fora de escopo/Riscos (máx 1 página)"
}

resolve() { # resolve <id> → caminho
  local id f; id=$(printf '%03d' "$((10#$1))")
  f=$(ls "$TASKS/${id}"-*.md "$TASKS/${id}.md" 2>/dev/null | head -1 || true)
  [ -n "$f" ] || { echo "erro: task $1 não encontrada" >&2; return 1; }
  echo "$f"
}

done_set() {
  local out=" " f
  for f in "$TASKS"/[0-9]*.md; do
    [ -e "$f" ] || continue
    [ "$(fm "$f" status)" = done ] && out+="$(fm "$f" id) "
  done
  echo "$out"
}

set_status() { # set_status <arquivo> <novo> — awk+mv (sed -i não é portável)
  awk -v s="$2" '
    /^---[ \t]*$/ { d++ }
    d==1 && /^status:/ && !done { print "status: " s; done=1; next }
    { print }
  ' "$1" > "$1.tmp" && mv "$1.tmp" "$1"
}

jlog() { # jlog <id> <texto...>
  local id="$1"; shift
  mkdir -p "$JOURNAL"
  echo "- $(now) $*" >> "$JOURNAL/$id.md"
}

cmd_status() {
  local todo=0 doing=0 dn=0 blocked=0 dset f st d
  dset=$(done_set)
  echo "id   st      size  title"
  for f in $(ls "$TASKS"/[0-9]*.md 2>/dev/null | sort); do
    st=$(fm "$f" status)
    case "$st" in
      todo)
        for d in $(fm "$f" depends); do
          case "$dset" in *" $d "*) ;; *) st=blocked ;; esac
        done
        [ "$st" = blocked ] && blocked=$((blocked+1)) || todo=$((todo+1)) ;;
      doing) doing=$((doing+1)) ;;
      done)  dn=$((dn+1)) ;;
    esac
    printf '%-4s %-7s %-5s %s\n' "$(fm "$f" id)" "$st" "$(fm "$f" size)" "$(fm "$f" title)"
  done
  echo "---"
  echo "todo:$todo  blocked:$blocked  doing:$doing  done:$dn"
  if [ -d "$CLAIMS" ] && [ -n "$(ls -A "$CLAIMS" 2>/dev/null)" ]; then
    echo "claims ativos:"
    local c
    for c in "$CLAIMS"/*/; do
      printf '  %s → %s\n' "$(basename "$c")" "$(cat "$c/owner" 2>/dev/null || echo '?')"
    done
  fi
  track "-" status 0
}

owner_of() { cut -d' ' -f1 "$CLAIMS/$1/owner" 2>/dev/null || true; }

require_owner() { # require_owner <id>
  local id="$1"
  [ -d "$CLAIMS/$id" ] || die "task $id sem claim — rode: ply claim $id --as <agente>"
  [ -n "$AS" ] || die "comando exige --as <agente> (ou export PLY_AS=...)"
  [ "$(owner_of "$id")" = "$AS" ] || die "claim de $id pertence a $(owner_of "$id"), não a $AS"
}

cmd_claim() {
  local f id; f=$(resolve "$1"); id=$(fm "$f" id)
  [ -n "$AS" ] || die "claim exige --as <agente> (ou export PLY_AS=...)"
  [ "$(fm "$f" status)" = todo ] || die "claim só em task todo (atual: $(fm "$f" status))"
  mkdir -p "$CLAIMS"
  mkdir "$CLAIMS/$id" 2>/dev/null || die "task $id já claimed por $(owner_of "$id")"
  printf '%s %s\n' "$AS" "$(now)" > "$CLAIMS/$id/owner"
  jlog "$id" "claim por $AS"
  echo "✓ claim $id → $AS"
}

cmd_release() {
  local f id; f=$(resolve "$1"); id=$(fm "$f" id)
  [ -d "$CLAIMS/$id" ] || die "task $id não tem claim"
  if [ -n "$AS" ] && [ "$(owner_of "$id")" != "$AS" ]; then
    die "claim de $id é de $(owner_of "$id"); para liberar como humano, rode sem --as"
  fi
  rm -rf "$CLAIMS/$id"
  [ "$(fm "$f" status)" = doing ] && set_status "$f" todo
  jlog "$id" "release ${AS:-manual}"
  echo "✓ release $id"
}

track() { # track <task|-> <cmd> <bytes>
  mkdir -p "$PLYD"
  printf '%s\t%s\t%s\t%s\n' "$(now)" "$1" "$2" "$3" >> "$USAGE"
}

cmd_brief() {
  local f out deps ds d dst
  f=$(resolve "$1")
  deps=$(fm "$f" depends)
  out="id:      $(fm "$f" id)
title:   $(fm "$f" title)
status:  $(fm "$f" status)
size:    $(fm "$f" size)"
  [ -n "$(fm "$f" spec)" ] && out+=$'\n'"spec:    specs/$(fm "$f" spec)-*.md (abra SÓ se o AC não bastar)"
  if [ -n "$deps" ]; then
    ds=""
    for d in $deps; do
      dst=$(fm "$(resolve "$d" 2>/dev/null || echo /dev/null)" status 2>/dev/null || echo "?")
      ds+="$d($dst) "
    done
    out+=$'\n'"depends: $ds"
  fi
  out+=$'\n'"files:   $(fm "$f" files)"
  out+=$'\n'"test:    $(fm "$f" test)"
  out+=$'\n'"---"
  out+=$'\n'"$(awk '/^---[ \t]*$/{d++;next} d>=2{print}' "$f")"
  printf '%s\n' "$out"
  track "$(fm "$f" id)" brief "$(printf '%s' "$out" | wc -c | tr -d ' ')"
}

claimed_files() {
  local out="" d f
  for d in "$CLAIMS"/*/; do
    [ -d "$d" ] || continue
    f=$(resolve "$(basename "$d")" 2>/dev/null) || continue
    out+=" $(fm "$f" files)"
  done
  echo "$out"
}

cmd_next() {
  local dset cfiles f id ok d x
  dset=$(done_set); cfiles=" $(claimed_files) "
  for f in $(ls "$TASKS"/[0-9]*.md 2>/dev/null | sort); do
    [ "$(fm "$f" status)" = todo ] || continue
    id=$(fm "$f" id)
    [ -d "$CLAIMS/$id" ] && continue
    ok=1
    for d in $(fm "$f" depends); do
      case "$dset" in *" $d "*) ;; *) ok=0; break ;; esac
    done
    [ "$ok" = 1 ] || continue
    for x in $(fm "$f" files); do
      case "$cfiles" in *" $x "*) ok=0; break ;; esac
    done
    [ "$ok" = 1 ] && { echo "$id"; track "$id" next 3; return 0; }
  done
  echo "NONE"; track "-" next 4
}

cmd_start() {
  local f id; f=$(resolve "$1"); id=$(fm "$f" id)
  require_owner "$id"
  [ "$(fm "$f" status)" = todo ] || die "start exige status todo (atual: $(fm "$f" status))"
  set_status "$f" doing
  jlog "$id" "start $AS"
  echo "→ $id doing ($AS)"
}

cmd_check() { # gate anti-alucinação: nada de done sem evidência
  local f id fail="" x t
  f=$(resolve "$1"); id=$(fm "$f" id)
  for x in $(fm "$f" files); do
    [ -f "$ROOT/$x" ] || [ -f "$x" ] || { echo "FAIL: arquivo declarado não existe: $x"; fail=1; }
  done
  t=$(fm "$f" test)
  if [ -n "$t" ]; then
    echo "→ rodando: $TEST_CMD $t"
    if eval "$TEST_CMD $t" > "$PLYD/last-test.log" 2>&1; then
      echo "PASS: teste verde"
    else
      echo "FAIL: teste vermelho (veja .ply/last-test.log)"; tail -5 "$PLYD/last-test.log"; fail=1
    fi
  else
    echo "AVISO: task sem test: — DoD não pode provar comportamento"
  fi
  if [ -z "$fail" ]; then
    jlog "$id" "check PASS"; echo "DoD: PASS"; return 0
  else
    jlog "$id" "check FAIL"; echo "DoD: FAIL"; return 1
  fi
}

cmd_done() {
  local f id; f=$(resolve "$1"); id=$(fm "$f" id)
  require_owner "$id"
  if cmd_check "$id"; then
    set_status "$f" done
    rm -rf "$CLAIMS/$id"
    jlog "$id" "done $AS (gate PASS)"
    echo "✓ $id done"
    echo "dica: ./ply lesson \"causa-raiz + fix\" se aprendeu algo não-óbvio"
  else
    die "não marcado done — gate falhou. Conserte o código ou registre um bug; nunca afrouxe o teste."
  fi
}

cmd_log() {
  local f id; f=$(resolve "$1"); id=$(fm "$f" id); shift
  require_owner "$id"
  [ -n "$*" ] || die "uso: ply log <id> --as <agente> \"<decisão>\""
  jlog "$id" "[$AS] $*"
  echo "registrado em journal/$id.md"
}

cmd_journal() {
  local f id; f=$(resolve "$1"); id=$(fm "$f" id)
  [ -f "$JOURNAL/$id.md" ] || die "task $id ainda não tem journal"
  cat "$JOURNAL/$id.md"
}

cmd_lesson() { # pheromone-lite: 1 linha, lida por skim no início da sessão
  [ -n "$*" ] || die "uso: ply lesson \"causa-raiz + fix + pegadinha\""
  [ -f "$LESSONS" ] || echo "# Lições (causa-raiz + fix). Skim as últimas ao começar a sessão." > "$LESSONS"
  echo "- $(now) $*" >> "$LESSONS"
  echo "registrado em $LESSONS"
}

cmd_fsck() {
  local f id st d ids=" " bad=0 pairs=""
  for f in "$TASKS"/[0-9]*.md; do
    [ -e "$f" ] || continue
    id=$(fm "$f" id); st=$(fm "$f" status)
    [ -n "$id" ] || { echo "FSCK: $f sem id"; bad=1; continue; }
    case "$ids" in *" $id "*) echo "FSCK: id duplicado: $id"; bad=1 ;; esac
    ids+="$id "
    case "$st" in todo|doing|done) ;; *) echo "FSCK: $id com status inválido: '$st'"; bad=1 ;; esac
    for d in $(fm "$f" depends); do
      resolve "$d" >/dev/null 2>&1 || { echo "FSCK: $id depende de $d (inexistente)"; bad=1; }
      pairs+="$d $id
"
    done
  done
  # tsort do BSD (macOS) avisa ciclo no stderr mas sai com rc=0; o do GNU sai !=0.
  # Portável: ciclo ⇔ tsort escreveu no stderr.
  if [ -n "$pairs" ]; then
    local cyc; cyc=$(printf '%s' "$pairs" | tsort 2>&1 >/dev/null)
    [ -n "$cyc" ] && { echo "FSCK: ciclo de dependências"; bad=1; }
  fi
  for d in "$CLAIMS"/*/; do
    [ -d "$d" ] || continue
    resolve "$(basename "$d")" >/dev/null 2>&1 || { echo "FSCK: claim órfão: $(basename "$d")"; bad=1; }
  done
  [ "$bad" = 0 ] && echo "fsck: OK" || return 1
}

cmd_metrics() {
  echo "== proxy: bytes servidos por task (.ply/usage.tsv) =="
  if [ -f "$USAGE" ]; then
    awk -F'\t' '{ b[$2]+=$4 } END { for (t in b) printf "%-6s %8d bytes\n", t, b[t] }' "$USAGE" | sort
  else
    echo "(sem uso registrado)"
  fi
  local id="${1:-}"; [ -n "$id" ] || return 0
  id=$(printf '%03d' "$((10#$id))")
  echo "== real (Claude Code): task $id =="
  local proj start end
  proj="${PLY_TRANSCRIPTS:-$HOME/.claude/projects/$(printf '%s' "$ROOT" | sed 's/[/._]/-/g')}"
  [ -d "$proj" ] || { echo "(transcripts não encontrados em $proj)"; return 0; }
  start=$(grep ' start ' "$JOURNAL/$id.md" 2>/dev/null | head -1 | awk '{print $2}')
  end=$(grep ' done ' "$JOURNAL/$id.md" 2>/dev/null | tail -1 | awk '{print $2}')
  [ -n "$start" ] || { echo "(task $id sem start no journal)"; return 0; }
  [ -n "$end" ] || end="9999"
  cat "$proj"/*.jsonl 2>/dev/null | awk -v s="$start" -v e="$end" '
    {
      ts = ""
      if (match($0, /"timestamp":"[^"]*"/)) ts = substr($0, RSTART+13, RLENGTH-14)
      if (ts == "" || ts < s || ts > e) next
      if (match($0, /"input_tokens":[0-9]+/))            it += substr($0, RSTART+15, RLENGTH-15)
      if (match($0, /"output_tokens":[0-9]+/))           ot += substr($0, RSTART+16, RLENGTH-16)
      if (match($0, /"cache_read_input_tokens":[0-9]+/)) cr += substr($0, RSTART+26, RLENGTH-26)
    }
    END { printf "input:%d output:%d cache_read:%d\n", it, ot, cr }' || true
}

usage() {
  cat <<'EOF'
ply — ledger de tarefas token-frugal (pull paralelo, gates determinísticos)

  ./ply init [--kit <dir>]            bootstrap + skill + bloco CLAUDE.md
  ./ply spec "<título>"               cria spec enxuta (1 página)
  ./ply new "<título>" [--spec N] [--dep "010 011"]
  ./ply next                          próxima: todo, deps done, sem claim, sem overlap
  ./ply claim <id> --as <agente>      lock atômico
  ./ply brief <id>                    contrato compacto de UMA task
  ./ply start <id> --as <agente>      todo → doing (só o dono)
  ./ply check <id>                    gate: files existem + teste verde
  ./ply done <id> --as <agente>       check + done + libera claim
  ./ply log <id> --as <agente> "<msg>"  decisão → journal
  ./ply release <id> [--as <agente>]  solta claim (sem --as = override humano)
  ./ply lesson "<txt>"                1 linha em tasks/LESSONS.md
  ./ply status                        placar + claims ativos
  ./ply journal <id>                  diário da task (para humanos)
  ./ply metrics [<id>]                proxy (bytes) + real (Claude Code)
  ./ply fsck                          valida o ledger
EOF
}

# pré-scan: extrai --as <nome> de qualquer posição
args=()
while [ $# -gt 0 ]; do
  case "$1" in
    --as) AS="${2:-}"; [ -n "$AS" ] || die "--as exige um nome"; shift 2 ;;
    *) args+=("$1"); shift ;;
  esac
done
set -- ${args[@]+"${args[@]}"}

case "${1:-}" in
  init)   shift; cmd_init "$@" ;;
  new)    shift; cmd_new "$@" ;;
  spec)   shift; cmd_spec "$*" ;;
  status) cmd_status ;;
  claim)  shift; cmd_claim "$@" ;;
  release) shift; cmd_release "$@" ;;
  next)   cmd_next ;;
  brief)  shift; cmd_brief "$@" ;;
  start)  shift; cmd_start "$@" ;;
  check)  shift; cmd_check "$@" ;;
  done)   shift; cmd_done "$@" ;;
  log)    shift; cmd_log "$@" ;;
  journal) shift; cmd_journal "$@" ;;
  lesson) shift; cmd_lesson "$@" ;;
  fsck)   cmd_fsck ;;
  metrics) shift; cmd_metrics "${1:-}" ;;
  ""|-h|--help|help) usage ;;
  *) echo "comando desconhecido: $1" >&2; usage; exit 1 ;;
esac
